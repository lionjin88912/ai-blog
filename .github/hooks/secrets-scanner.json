      {
        "type": "command",
        "bash": ".github/hooks/secrets-scanner/scan-secrets.sh",
        "powershell": ".github/hooks/secrets-scanner/scan-secrets.ps1",
        "cwd": ".",
        "env": {
          "SCAN_MODE": "block",
          "SCAN_SCOPE": "staged"
        },
