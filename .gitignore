# ============================================================
# 機密 — 絕對不可進 git
# ============================================================
# WordPress 連線設定卡(含真實帳密與應用程式密碼)
**/wp-config.json
# 其他可能的本地秘密檔
.env
.env.local
*.pem
*.key

# ============================================================
# 自動下載/產生的工具與環境(體積大,各機器自建)
# ============================================================
sandbox/
.venv/
node_modules/
ai-blog-*
ai-sandbox-*

# ============================================================
# 歸檔與舊版
# ============================================================
.agents/_archive/

# ============================================================
# 臨時與執行時產生的檔案
# ============================================================
# 圖片 API 用的暫存請求
request.json
# 寫文章產生的 HTML 草稿(統一放在各人格資料夾下)
.agents/skills/persona-writer/personas/*/articles/
# 空的 workspace 暫存
workspace/

# ============================================================
# 每台機器自己產生的狀態檔
# ============================================================
# tool-status-checker 跑 check env 後產生,每台機器都不同
TOOLS.md
# 每個人格的發文紀錄(內含真實 WordPress URL,各機器獨立)
**/published.json

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# ============================================================
# Node
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package.json
package-lock.json

# ============================================================
# 通用 log 與快取
# ============================================================
*.log
logs/
.cache/

# ============================================================
# 備份與暫存檔
# ============================================================
*.bak
*.tmp
*~
gemini_ai_cli.zip

# ============================================================
# 作業系統
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# IDE / 編輯器
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# ai-sandbox 種子(build 時由 make seed-sync 產生)
# ============================================================
sandbox-src/internal/seed/content/*
!sandbox-src/internal/seed/content/README.md
sandbox-src/ai-blog
sandbox-src/dist/

# ============================================================
# 人格資料夾:官方只出廠 _template 與 mrs-lin;其餘為各機本地人格
# (業務用 marketing-content-factory 模組 5 在本機自建,不進 git、不出廠)
# ============================================================
.agents/skills/persona-writer/personas/*/
!.agents/skills/persona-writer/personas/_template/
!.agents/skills/persona-writer/personas/mrs-lin-slow-travel/

# icon 工具鏈(syso/ico/json 要進 git,工具本體不用)
sandbox-src/build/goversioninfo
