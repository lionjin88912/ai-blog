# ============================================================
# 機密 — 絕對不可進 git
# ============================================================
# WordPress 連線設定卡(含真實帳密與應用程式密碼)
**/wp-config.json
# 其他可能的本地秘密檔
.env
.env.local
*.pem
*.key

# ============================================================
# 自動下載/產生的工具與環境(體積大,各機器自建)
# ============================================================
sandbox/
.venv/
node_modules/

# ============================================================
# 歸檔與舊版
# ============================================================
.gemini/_archive/

# ============================================================
# 臨時與執行時產生的檔案
# ============================================================
# 圖片 API 用的暫存請求
request.json
# 寫文章產生的 HTML 草稿(統一放在各人格資料夾下)
.gemini/skills/persona-writer/personas/*/articles/
# 空的 workspace 暫存
workspace/

# ============================================================
# 每台機器自己產生的狀態檔
# ============================================================
# tool-status-checker 跑 check env 後產生,每台機器都不同
TOOLS.md
# 每個人格的發文紀錄(內含真實 WordPress URL,各機器獨立)
**/published.json

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# ============================================================
# Node
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# 通用 log 與快取
# ============================================================
*.log
logs/
.cache/

# ============================================================
# 備份與暫存檔
# ============================================================
*.bak
*.tmp
*~

# ============================================================
# 作業系統
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# IDE / 編輯器
# ============================================================
.vscode/
.idea/
*.swp
*.swo
