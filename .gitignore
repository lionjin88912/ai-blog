.env
.env.local
*.pem
*.key

# ============================================================
# 自動下載/產生的工具與環境(體積大,各機器自建)
# ============================================================
sandbox/
.venv/
node_modules/

# ============================================================
# 歸檔與舊版
# ============================================================
.gemini/_archive/

# ============================================================
# 臨時與執行時產生的檔案
# ============================================================
# 圖片 API 用的暫存請求
request.json
# 產生的文章 HTML(每次寫文章都會在頂層產生一個資料夾)
/mrs-lin-slow-travel/
/mr-wang-foodie/
# 空的 workspace 暫存
workspace/

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# ============================================================
